# Copy this file to .env for local development (docker-compose or manual export).
# On Render, set these as Environment Variables in the service dashboard instead —
# do not commit real secrets to the repository.

# ASP.NET Core environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development

# Port Kestrel listens on inside the container (Render sets this automatically in production)
PORT=8080

# PostgreSQL connection (Neon). Accepts either format:
#   postgres://user:password@host/dbname?sslmode=require   (Neon connection string)
#   Host=...;Port=...;Database=...;Username=...;Password=...;SSL Mode=Require;
DATABASE_URL=postgres://user:password@host.neon.tech/aurum?sslmode=require

# Comma-separated list of origins allowed to call the API (e.g. the Vercel frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Rate limiting (requests per window, per client IP)
RATELIMITING__PERMITLIMIT=100
RATELIMITING__WINDOWSECONDS=60
RATELIMITING__QUEUELIMIT=0

# JWT authentication (Authentication feature).
# Signing key is a flat env var (same convention as DATABASE_URL) since it's
# a secret most secret managers store as a single value, not nested under
# Jwt__*. Must be at least 32 bytes / 256 bits for HS256. Generate one with:
#   openssl rand -base64 48
JWT_SIGNING_KEY=replace-with-a-long-random-secret-at-least-32-bytes

# Optional overrides (standard ASP.NET Core Section__Key convention)
JWT__ISSUER=Aurum.Api
JWT__AUDIENCE=Aurum.Client
JWT__ACCESSTOKENEXPIRYMINUTES=60
