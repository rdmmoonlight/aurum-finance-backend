# Copy this file to .env for local development, or set these as real
# environment variables in your hosting platform (Render, etc). Never
# commit an actual .env file or a real value for any of these.

# PostgreSQL connection string (Neon/Render convention: a single
# "postgresql://user:password@host/db?sslmode=require" URL). Required —
# see Core/Extensions/DatabaseServiceExtensions.cs.
DATABASE_URL=postgresql://neondb_owner:npg_SIwmzB1AdMk4@ep-wandering-bread-ao1sazxn-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Required. At least 32 bytes of random data — e.g. `openssl rand -base64 32`.
JWT_SIGNING_KEY=VBnN6vw59KiZl+vRutcTdy+HD8mkknjxYOgxcpiI9pg=

# Optional overrides (standard ASP.NET Core Section__Key convention)
JWT__ISSUER=Aurum.Api
JWT__AUDIENCE=Aurum.Client
JWT__ACCESSTOKENEXPIRYMINUTES=60
JWT__REFRESHTOKENEXPIRYDAYS=30

# Account lockout + one-time-token lifetimes (Authentication feature).
AUTH__MAXFAILEDLOGINATTEMPTS=5
AUTH__LOCKOUTMINUTES=15
AUTH__EMAILVERIFICATIONTOKENEXPIRYHOURS=24
AUTH__PASSWORDRESETTOKENEXPIRYMINUTES=60

# Comma-separated list of origins allowed to call this API from a browser
# (see Core/Extensions/CorsServiceExtensions.cs). Leave unset in local dev
# if you're only calling the API server-side.
ALLOWED_ORIGINS=http://localhost:3000
